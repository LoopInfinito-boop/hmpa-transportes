<script>
let step=1;
function setCircle(i,state){
  const c=document.getElementById('sc'+i), l=document.getElementById('stl'+i), ln=document.getElementById('sl'+i);
  if(state==='done'){c.style.cssText='width:26px;height:26px;border-radius:50%;border:2px solid var(--green);background:var(--green);color:#000;display:flex;align-items:center;justify-content:center;margin:0 auto 5px;font-size:12px;font-weight:700;position:relative;z-index:1;';c.textContent='✓';if(ln)ln.style.background='var(--green)';}
  else if(state==='active'){c.style.cssText='width:26px;height:26px;border-radius:50%;border:2px solid var(--green);background:var(--bg);color:var(--green);display:flex;align-items:center;justify-content:center;margin:0 auto 5px;font-size:12px;font-weight:700;position:relative;z-index:1;';c.textContent=i;l.style.color='var(--green)';l.style.fontWeight='700';}
  else{c.style.cssText='width:26px;height:26px;border-radius:50%;border:2px solid var(--border);background:var(--bg);color:var(--text2);display:flex;align-items:center;justify-content:center;margin:0 auto 5px;font-size:12px;font-weight:700;position:relative;z-index:1;';c.textContent=i;l.style.color='var(--text2)';l.style.fontWeight='400';}
}
function goStep(n){
  if(n>step){
    if(step===1&&!document.getElementById('tipo-veiculo').value){alert('Selecione o tipo de veículo.');return;}
    if(step===2){
      if(!document.getElementById('sel-origem').value){alert('Selecione a origem.');return;}
      if(!document.getElementById('sel-destino').value){alert('Selecione o destino.');return;}
      if(document.getElementById('sel-origem').value===document.getElementById('sel-destino').value){alert('Origem e destino não podem ser iguais.');return;}
    }
    if(n===4)buildReview();
  }
  document.getElementById('s'+step).style.display='none';
  step=n;
  document.getElementById('s'+step).style.display='block';
  for(let i=1;i<=4;i++) setCircle(i,i<step?'done':i===step?'active':'pending');
}
function toggleTipo(){
  const t=document.getElementById('tipo-veiculo').value;
  document.getElementById('apoio-cat').style.display=t==='apoio'?'block':'none';
  document.getElementById('form-amb').style.display=t==='ambulancia'?'block':'none';
  document.getElementById('form-apoio-itens').style.display=t==='apoio'?'block':'none';
}
function buildReview(){
  const t=document.getElementById('tipo-veiculo').value;
  const orig=document.getElementById('sel-origem').selectedOptions[0]?.text||'—';
  const dest=document.getElementById('sel-destino').selectedOptions[0]?.text||'—';
  const pNome=document.querySelector('[name="p_nome"]')?.value||'—';
  const pPront=document.querySelector('[name="p_prontuario"]')?.value||'—';
  const pEstado=document.querySelector('[name="p_estado"]')?.value||'—';
  const catApoio=document.querySelector('[name="categoria_apoio"]')?.value||'—';
  const descApoio=document.querySelector('[name="descricao_apoio"]')?.value||'—';
  document.getElementById('review-box').innerHTML=`
    <div style="margin-bottom:10px;display:flex;gap:8px;flex-wrap:wrap;">
      <span class="pill pill-gray">${t==='ambulancia'?'🚑 Ambulância':'🚗 Carro de apoio'}</span>
    </div>
    <div class="form-grid">
      <div><b>Origem:</b><br/>${orig}</div>
      <div><b>Destino:</b><br/>${dest}</div>
      ${t==='ambulancia'?`<div><b>Paciente:</b><br/>${pNome}</div><div><b>Prontuário:</b><br/>${pPront}</div><div><b>Estado clínico:</b><br/>${pEstado}</div>`:''}
      ${t==='apoio'?`<div><b>Categoria:</b><br/>${catApoio}</div><div><b>Descrição:</b><br/>${descApoio}</div>`:''}
    </div>`;
}
function addItem(){
  const l=document.getElementById('itens-lista');
  const d=document.createElement('div');d.className='apoio-item';
  d.style.cssText='display:grid;grid-template-columns:2fr 1fr 1fr auto;gap:10px;margin-bottom:8px;align-items:end;';
  d.innerHTML='<div class="f-group"><label class="f-label">Item</label><input class="f-input" name="item_nome[]" placeholder="Descrição"/></div><div class="f-group"><label class="f-label">Qtde</label><input class="f-input" name="item_qtde[]"/></div><div class="f-group"><label class="f-label">Setor</label><input class="f-input" name="item_setor[]"/></div><div class="f-group"><label class="f-label" style="opacity:0;">.</label><button type="button" class="btn btn-red btn-sm" onclick="remItem(this)"><i class="ti ti-trash"></i></button></div>';
  l.appendChild(d);
}
function remItem(btn){btn.closest('.apoio-item').remove();}
</script>
