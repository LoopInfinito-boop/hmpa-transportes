}

async function nominatimSearch(q){
  const loading=document.getElementById('sr-loading');
  try{
    // Busca com bias para Belém mas sem restrição — retorna resultados globais
    const p=new URLSearchParams({
      q, format:'jsonv2', addressdetails:1, extratags:1, namedetails:1,
      limit:10, 'accept-language':'pt-BR,pt,en',
      viewbox:PARA_BBOX, bounded:0,
    });
    const r=await fetch(`https://nominatim.openstreetmap.org/search?${p}`,{
      headers:{'Accept-Language':'pt-BR,pt;q=0.9,en;q=0.8'}
    });
    const data=await r.json();
    loading.style.display='none';
    if(!data.length){
      // Segunda tentativa — busca global sem viewbox
      await nominatimGlobal(q);
      return;
    }
    renderNominatimResults(data,q);
  }catch(e){loading.style.display='none';}
}

async function nominatimGlobal(q){
  const loading=document.getElementById('sr-loading');
  loading.style.display='block';
  try{
    const p=new URLSearchParams({q,format:'jsonv2',addressdetails:1,extratags:1,namedetails:1,limit:7,'accept-language':'pt-BR,pt,en'});
    const r=await fetch(`https://nominatim.openstreetmap.org/search?${p}`,{headers:{'Accept-Language':'pt-BR,pt;q=0.9'}});
    const data=await r.json();
    loading.style.display='none';
    if(!data.length){
      document.getElementById('sr-body').innerHTML+=`<div class="sr-empty"><i class="ti ti-map-off"></i>Nenhum resultado para "<b>${q}</b>"<br/><small>Tente um endereço mais específico</small></div>`;
      return;
    }
    renderNominatimResults(data,q,true);
  }catch(e){loading.style.display='none';}
}

function renderNominatimResults(data,q,isGlobal=false){
  const body=document.getElementById('sr-body');
  const bl=ORIGIN[0],bg=ORIGIN[1];
  const nearby=[], others=[];
  data.forEach(p=>{
    p._d=DB.stDist(bl,bg,parseFloat(p.lat),parseFloat(p.lon));
    (p._d<60?nearby:others).push(p);
  });

  function getIcon(p){
    const c=p.class||'',t=p.type||'';
    if(c==='amenity'&&['hospital','clinic','doctors','dentist','pharmacy'].includes(t))return{i:'ti-building-hospital',cls:'hosp'};
    if(c==='highway'||['road','residential','street_address'].includes(t))return{i:'ti-road',cls:'road'};
    if(c==='place'&&['city','town','village','municipality','suburb'].includes(t))return{i:'ti-building',cls:'city'};
    if(c==='place'&&t==='country')return{i:'ti-world',cls:''};
    if(c==='amenity'&&['school','university','college'].includes(t))return{i:'ti-school',cls:''};
    if(c==='shop')return{i:'ti-shopping-cart',cls:''};
    if(c==='tourism')return{i:'ti-camera',cls:''};
    if(c==='leisure'||c==='natural')return{i:'ti-tree',cls:''};
    if(c==='amenity'&&['restaurant','cafe','fast_food','bar'].includes(t))return{i:'ti-tool-kitchen-2',cls:''};
    return{i:'ti-map-pin',cls:''};
  }

  function highlight(text,q){
    if(!q||!text)return text||'';
    const re=new RegExp('('+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi');
    return text.replace(re,'<b>$1</b>');
  }

  function fmtDist(km){
    return km<1?(km*1000).toFixed(0)+' m':km.toFixed(1)+' km';
  }

  function renderItem(p){
    const a=p.address||{};
    const name=p.namedetails?.name||p.name||p.display_name.split(',')[0];
    const addrParts=[a.road,a.suburb||a.neighbourhood||a.district,a.city||a.town||a.village,a.state,a.country].filter(Boolean).filter((v,i,arr)=>arr.indexOf(v)===i);
    const addr=addrParts.slice(0,3).join(', ')||p.display_name.split(',').slice(1,3).join(',').trim();
    const dist=fmtDist(p._d);
    const ic=getIcon(p);
    const ne=name.replace(/'/g,"\\'");
    const ae=addr.replace(/'/g,"\\'");
    return `<div class="sr-result" onclick="pickNominatim(${p.lat},${p.lon},'${ne}','${ae}')">
      <div class="sr-r-ic ${ic.cls}"><i class="ti ${ic.i}"></i></div>
      <div style="flex:1;min-width:0;">
        <div class="sr-r-name">${highlight(name,q)}</div>
        <div class="sr-r-addr">${addr}</div>
      </div>
      <div class="sr-r-dist">${dist}</div>
    </div>`;
  }

  // Preserva resultados do hospital no topo
  const existing=[...body.querySelectorAll('.sr-result[data-local]')].map(e=>e.outerHTML).join('');
  let html=existing;

  if(nearby.length){
    html+=`<div class="sr-group-label green"><i class="ti ti-map-pin-filled" style="font-size:12px;"></i> Próximo a Belém</div>`;
    html+=nearby.map(renderItem).join('');
  }
  if(others.length){
    html+=`<div class="sr-group-label"><i class="ti ti-world" style="font-size:12px;"></i> Outros lugares</div>`;
    html+=others.map(renderItem).join('');
  }
  html+=`<div class="sr-footer"><i class="ti ti-map" style="font-size:13px;"></i><span>Nominatim · OpenStreetMap contributors</span></div>`;
  body.innerHTML=html;
  document.getElementById('sr-container').scrollTop=0;
}

function renderLocalResults(filter){
  const body=document.getElementById('sr-body');
  const list=filter?DB.destinations.filter(d=>d.name.toLowerCase().includes(filter.toLowerCase())):DB.destinations;
  if(!list.length&&filter){body.innerHTML='';return;}
  let html=`<div class="sr-group-label green" style="border-top:none;"><i class="ti ti-building-hospital" style="font-size:12px;"></i> Destinos do hospital</div>`;
  html+=list.map(d=>`
    <div class="sr-result" data-local="1" onclick="pickLocal(${d.id})">
      <div class="sr-r-ic hosp"><i class="ti ti-building-hospital"></i></div>
      <div style="flex:1;min-width:0;">
        <div class="sr-r-name">${d.name}</div>
        <div class="sr-r-addr">${d.info?d.info+' · ':''}${d.cat}</div>
      </div>
      <div class="sr-r-dist">${d.dist} km</div>
