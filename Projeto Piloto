  buildVeiculosList();buildMenu();
  closeSheet('sh-veiculos');
  toast('[DB] INSERT INTO vehicles: '+id+' ✓');
}
function addDestino(){
  const n=document.getElementById('nd-name').value;
  if(!n){toast('Informe o nome do local.');return;}
  const km=parseFloat(document.getElementById('nd-km').value)||0;
  DB.insert('destinations',{name:n,cat:document.getElementById('nd-tipo').value,info:document.getElementById('nd-addr').value,dist:km,lat:ORIGIN[0],lng:ORIGIN[1]});
  buildDestinosList();buildHomeRecent();buildMenu();renderLocalResults('');
  document.getElementById('nd-name').value='';
  closeSheet('sh-destinos');
  toast('[PostGIS] INSERT INTO destinations (ST_GeomFromText): '+n+' ✓');
}

// ══════════════════════════════════════════════
//  RIDE FLOW
// ══════════════════════════════════════════════
function confirmRide(){
  gotoScr('scr-confirm');
  document.getElementById('riding-dest-name').textContent=selDest?.name||'—';
  setTimeout(()=>{
    document.getElementById('conf-st').textContent='Motorista encontrado!';
    document.getElementById('conf-sub').textContent='João Rodrigues está a caminho';
    document.getElementById('conf-spin').style.display='none';
    document.getElementById('drv-preview').style.opacity='1';
    setTimeout(()=>{gotoScr('scr-riding');document.getElementById('eta-pill').style.display='block';},2500);
  },3000);
}

function cancelRide(){
  document.getElementById('eta-pill').style.display='none';
  if(routeLayer){map.removeLayer(routeLayer);routeLayer=null;}
  if(destMk){map.removeLayer(destMk);destMk=null;}
  map.setView(ORIGIN,16);
  gotoScr('scr-home');
  toast('Solicitação cancelada.');
}

function finishRide(){
  document.getElementById('eta-pill').style.display='none';
  if(routeLayer){map.removeLayer(routeLayer);routeLayer=null;}
  if(destMk){map.removeLayer(destMk);destMk=null;}
  map.setView(ORIGIN,16);
  DB.insert('trips',{date:'Agora',orig:'HMPá',dest:tripData.dest||'—',drv:'João Rodrigues',veh:'Amb.01',km:parseFloat(tripData.km||0),min:tripData.min||0,hod_i:85000,hod_f:85000+parseFloat(tripData.km||0),cost:parseFloat(tripData.km||0)*0.8,ok:true});
  document.getElementById('earn-trips').textContent=parseInt(document.getElementById('earn-trips').textContent)+1;
  console.log(`[PostGIS] INSERT INTO trips: ${tripData.dest} · ${tripData.km}km`);
  gotoScr('scr-rating');
}

function showRecibo(orig,dest,custo,date,hod){
  document.getElementById('rec-v').textContent=custo;
  document.getElementById('rec-d').textContent=date;
  document.getElementById('rec-route').innerHTML=`<div style="font-size:13px;font-weight:700;margin-bottom:5px;">📍 ${orig}</div><div style="font-size:12px;color:var(--muted);margin:3px 0 3px 16px;">↓</div><div style="font-size:13px;font-weight:700;">📍 ${dest}</div>`;
  const hs=hod.split('→');
  document.getElementById('rec-hod-i').textContent=(hs[0]?.trim()||'—')+' km';
  document.getElementById('rec-hod-f').textContent=(hs[1]?.trim()||'—')+' km';
  openSheet('sh-recibo');
}

// ══════════════════════════════════════════════
//  MISC
// ══════════════════════════════════════════════
function rateStar(n){rating=n;document.querySelectorAll('.star').forEach((s,i)=>s.classList.toggle('on',i<n));}
function submitRating(){
  const tags=[...document.querySelectorAll('.rtag.sel')].map(t=>t.textContent);
  toast('Avaliação enviada! ★'.repeat(rating)+(tags.length?' · '+tags.join(', '):''));
  gotoScr('scr-home');
}

function sendMsg(){
  const inp=document.getElementById('chat-in');
  if(!inp.value.trim())return;
  const msgs=document.getElementById('chat-msgs');
  const t=new Date(),time=t.getHours()+':'+String(t.getMinutes()).padStart(2,'0');
  msgs.innerHTML+=`<div class="msg me">${inp.value}<div class="msg-time">${time}</div></div>`;
  const v=inp.value;inp.value='';msgs.scrollTop=msgs.scrollHeight;
  setTimeout(()=>{msgs.innerHTML+=`<div class="msg other">Ok, entendido! Já estou chegando.<div class="msg-time">${time}</div></div>`;msgs.scrollTop=msgs.scrollHeight;},1500);
}

function toggleOnline(){
  const on=document.getElementById('tog-btn').classList.toggle('on');
  document.getElementById('online-lbl').textContent=on?'Online':'Offline';
  toast(on?'Você está online — recebendo solicitações.':'Você está offline.');
}

function acceptReq(){
  document.getElementById('req-card').innerHTML=`
    <div style="text-align:center;padding:8px 0;">
      <div style="font-size:16px;font-weight:800;color:var(--green);margin-bottom:6px;">✓ Corrida aceita!</div>
      <div style="font-size:13px;color:var(--muted);">A caminho do Pronto-socorro</div>
      <div style="margin-top:14px;"><button class="btn" style="padding:11px;" onclick="gotoScr('scr-chat')"><i class="ti ti-message"></i> Falar com solicitante</button></div>
    </div>`;
  toast('Corrida aceita! Navegando até o solicitante.');
}
function rejectReq(){document.getElementById('req-card').style.display='none';toast('Corrida recusada.');}
function closeInc(accept){document.getElementById('inc-overlay').classList.remove('open');if(accept)acceptReq();else rejectReq();}

function addStop(){
  if(stops>=2){toast('Máximo de 2 paradas intermediárias.');return;}
  stops++;
  const wrap=document.getElementById('extra-stops');
  const d=document.createElement('div');
  d.innerHTML=`<div class="rp-row"><div class="rp-dot" style="background:var(--amber);"></div><input class="rp-input" placeholder="Parada ${stops}…"/></div><div class="rp-vline" style="margin-left:5px;"></div>`;
  wrap.appendChild(d);
}

function selSvc(el,v){document.querySelectorAll('.svc').forEach(s=>s.classList.remove('sel'));el.classList.add('sel');svcVal=v;}
function selVtype(el,t){
  document.querySelectorAll('.vtc').forEach(c=>c.classList.remove('sel'));el.classList.add('sel');vtypeVal=t;
  document.getElementById('form-amb').style.display=t==='amb'?'block':'none';
  document.getElementById('form-apoio').style.display=t==='apoio'?'block':'none';
}

// NAVIGATION
function gotoScr(id){
  if(id!==curScr()) prevScr=curScr();
  document.querySelectorAll('.scr').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if(id==='scr-dest'){setTimeout(()=>{document.getElementById('dest-input').focus();renderLocalResults('');},200);}
  setTimeout(()=>map.invalidateSize(),100);
}
function curScr(){return [...document.querySelectorAll('.scr')].find(s=>s.classList.contains('active'))?.id||'scr-home';}
function goBack(){gotoScr(prevScr||'scr-home');}
function setNav(btn){const nav=btn.closest('.nav-bar');if(nav)nav.querySelectorAll('.nav-btn').forEach(b=>b.classList.toggle('on',b===btn));}
function openSheet(id){document.getElementById(id).classList.add('open');}
function closeSheet(id){document.getElementById(id).classList.remove('open');}
function closeBg(e,id){if(e.target===e.currentTarget)closeSheet(id);}
function toast(msg){const t=document.getElementById('toast-bar');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3200);}

// INIT
gotoScr('scr-login');
</script>
</body>
</html>
