// ══════════════════════════════════════════════
//  OSRM ROUTING
// ══════════════════════════════════════════════
async function drawRoute(lat,lng,name){
  if(routeLayer){map.removeLayer(routeLayer);routeLayer=null;}
  if(destMk){map.removeLayer(destMk);destMk=null;}
  const dIcon=L.divIcon({html:'<div style="width:14px;height:14px;background:#fff;border-radius:50%;border:3px solid #000;box-shadow:0 2px 8px rgba(0,0,0,.6);"></div>',iconSize:[14,14],iconAnchor:[7,7],className:''});
  destMk=L.marker([lat,lng],{icon:dIcon}).addTo(map).bindPopup(`<b style="font-size:13px;">${name}</b>`);
  try{
    const url=`https://router.project-osrm.org/route/v1/driving/${ORIGIN[1]},${ORIGIN[0]};${lng},${lat}?overview=full&geometries=geojson`;
    const r=await fetch(url);
    const d=await r.json();
    if(d.code==='Ok'){
      const rt=d.routes[0];
      const km=(rt.distance/1000).toFixed(1);
      const min=Math.round(rt.duration/60);
      routeLayer=L.geoJSON(rt.geometry,{style:{color:'#06C167',weight:5,opacity:.92,lineCap:'round',lineJoin:'round'}}).addTo(map);
      // Fit bounds com padding para o painel
      map.fitBounds(routeLayer.getBounds(),{paddingTopLeft:[420,80],paddingBottomRight:[60,60]});
      ['km-amb','km-apoio'].forEach(id=>document.getElementById(id).textContent=km+' km');
      document.getElementById('cf-km').textContent=km+' km';
      document.getElementById('cf-eta').textContent=min+' min';
      document.getElementById('cf-custo').textContent='R$'+(km*0.8).toFixed(2);
      document.getElementById('cf-hod').textContent=(85000+parseFloat(km)).toFixed(1)+' km';
      document.getElementById('eta-pill').textContent='🚑 Chegando em ~'+min+' min';
      document.getElementById('route-summary').innerHTML=`<b>${name}</b> · <b style="color:var(--green);">${km} km</b> · ~${min} min · via <b>OSRM</b>`;
      tripData={km,min,custo:'R$'+(km*0.8).toFixed(2),dest:name,hod:'85.000 → '+(85000+parseFloat(km)).toFixed(1)};
      console.log(`[OSRM] Rota: ${km}km · ${min}min`);
    }
  }catch(e){
    document.getElementById('route-summary').textContent='Erro ao calcular rota. Verifique a conexão.';
    console.error('OSRM:',e);
  }
}

