<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>HMPá Transportes</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.css"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
:root{
  --green:#06C167;--gd:#048848;--red:#D1293D;--amber:#F5A623;--blue:#276EF1;
  --bg:#000;--s1:#111;--s2:#1a1a1a;--s3:#242424;--border:#2a2a2a;--muted:#6b6b6b;
  --text:#fff;--r:10px;--font:'Inter',system-ui,sans-serif;
  --panel:400px;
}
html,body{height:100%;font-family:var(--font);background:var(--bg);color:var(--text);overflow:hidden;font-size:14px;line-height:1.5;}

/* ════ LAYOUT ════ */
#app{display:flex;height:100vh;width:100vw;}
#panel{width:var(--panel);min-width:var(--panel);height:100vh;background:var(--bg);display:flex;flex-direction:column;border-right:1px solid var(--border);overflow:hidden;position:relative;z-index:10;}
#map-area{flex:1;position:relative;overflow:hidden;}
#map{position:absolute;inset:0;z-index:1;}

/* ════ MAP STYLING ════ */
.leaflet-tile-pane{filter:brightness(.7) saturate(.6) contrast(1.2) hue-rotate(3deg);}
.leaflet-control-attribution{display:none!important;}
.leaflet-control-zoom{left:auto!important;right:16px!important;bottom:120px!important;top:auto!important;}
.leaflet-control-zoom a{
  width:38px!important;height:38px!important;line-height:38px!important;
  background:rgba(0,0,0,.85)!important;backdrop-filter:blur(8px);
  color:var(--text)!important;border:1px solid var(--border)!important;
  font-size:18px!important;border-radius:8px!important;
}
.leaflet-control-zoom a:hover{background:var(--s2)!important;}
.leaflet-control-zoom-in{border-radius:8px 8px 0 0!important;margin-bottom:1px!important;}
.leaflet-control-zoom-out{border-radius:0 0 8px 8px!important;}
.leaflet-popup-content-wrapper{background:var(--s1);color:var(--text);border:1px solid var(--border);border-radius:var(--r);box-shadow:0 8px 32px rgba(0,0,0,.6);}
.leaflet-popup-tip{background:var(--s1);}
.leaflet-popup-content{font-family:var(--font);font-size:13px;margin:10px 14px;}

/* ════ MAP CONTROLS (floating) ════ */
.map-fab{position:absolute;z-index:10;width:42px;height:42px;border-radius:50%;background:rgba(0,0,0,.85);backdrop-filter:blur(8px);border:1px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text);font-size:17px;box-shadow:0 4px 16px rgba(0,0,0,.5);transition:background .15s;}
.map-fab:hover{background:var(--s2);}
.eta-ribbon{position:absolute;top:16px;left:50%;transform:translateX(-50%);z-index:10;background:rgba(0,0,0,.9);backdrop-filter:blur(8px);border:1px solid var(--border);border-radius:24px;padding:9px 22px;font-size:13px;font-weight:700;white-space:nowrap;box-shadow:0 4px 16px rgba(0,0,0,.5);display:none;}
.map-legend{position:absolute;bottom:16px;right:60px;z-index:10;background:rgba(0,0,0,.8);backdrop-filter:blur(8px);border:1px solid var(--border);border-radius:var(--r);padding:8px 14px;font-size:11px;color:var(--muted);display:flex;align-items:center;gap:8px;}
.db-pill{position:absolute;bottom:16px;left:16px;z-index:10;background:rgba(0,0,0,.8);backdrop-filter:blur(8px);border:1px solid var(--border);border-radius:20px;padding:6px 12px;font-size:11px;font-weight:600;color:var(--muted);display:flex;align-items:center;gap:6px;}
.db-pill.ok{color:var(--green);border-color:rgba(6,193,103,.3);}

/* ════ PANEL COMMON ════ */
.scr{display:none;flex-direction:column;height:100%;overflow:hidden;}
.scr.active{display:flex;}
.ph{padding:20px 24px 14px;flex-shrink:0;}
.ph-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:0;}
.ph-title{font-size:17px;font-weight:700;}
.ph-sub{font-size:12px;color:var(--muted);margin-top:3px;}
.panel-scroll{flex:1;overflow-y:auto;}
.panel-scroll::-webkit-scrollbar{width:4px;}
.panel-scroll::-webkit-scrollbar-thumb{background:var(--s3);border-radius:2px;}
.panel-scroll::-webkit-scrollbar-track{background:transparent;}
.divider{height:1px;background:var(--border);margin:0;}
.p-footer{padding:16px 24px;border-top:1px solid var(--border);flex-shrink:0;}

/* ════ NAV BAR ════ */
.nav-bar{display:flex;border-top:1px solid var(--border);flex-shrink:0;background:var(--bg);}
.nav-btn{flex:1;padding:11px 4px;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;border:none;background:transparent;color:var(--muted);font-family:var(--font);transition:color .15s;position:relative;}
.nav-btn.on,.nav-btn:hover{color:var(--text);}
.nav-btn i{font-size:20px;}
.nav-btn span{font-size:10px;font-weight:600;}
.nav-btn::after{content:'';position:absolute;top:0;left:25%;right:25%;height:2px;background:var(--green);border-radius:0 0 2px 2px;opacity:0;transition:opacity .15s;}
.nav-btn.on::after{opacity:1;}

/* ════ BUTTONS ════ */
.btn{width:100%;padding:13px;background:var(--green);color:#000;font-size:14px;font-weight:800;border:none;border-radius:var(--r);cursor:pointer;font-family:var(--font);display:flex;align-items:center;justify-content:center;gap:8px;transition:all .15s;}
.btn:hover{background:var(--gd);color:#fff;}
.btn-ghost{width:100%;padding:12px;background:transparent;color:var(--text);font-size:13px;font-weight:600;border:1.5px solid var(--border);border-radius:var(--r);cursor:pointer;font-family:var(--font);transition:all .15s;display:flex;align-items:center;justify-content:center;gap:6px;}
.btn-ghost:hover{background:var(--s2);border-color:var(--muted);}
.btn-icon{width:36px;height:36px;border-radius:50%;background:var(--s2);border:1px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text);font-size:16px;transition:background .15s;flex-shrink:0;}
.btn-icon:hover{background:var(--s3);}
.badge-dot{position:absolute;top:5px;right:5px;width:7px;height:7px;border-radius:50%;background:var(--red);border:1.5px solid var(--bg);}

/* ════ FORMS ════ */
.f-grp{margin-bottom:12px;}
.f-lbl{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.05em;text-transform:uppercase;margin-bottom:5px;display:block;}
.f-in{width:100%;background:var(--s2);border:1.5px solid var(--border);border-radius:var(--r);padding:11px 14px;font-size:14px;color:var(--text);font-family:var(--font);outline:none;transition:border .15s;}
.f-in:focus{border-color:var(--green);}
.f-sel{width:100%;background:var(--s2);border:1.5px solid var(--border);border-radius:var(--r);padding:11px 14px;font-size:14px;color:var(--text);font-family:var(--font);outline:none;appearance:none;cursor:pointer;}
.f-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

/* ════ LOGIN ════ */
#scr-login .panel-scroll{padding:0 24px 24px;}
.login-logo{font-size:32px;font-weight:900;letter-spacing:-1px;margin:4px 0 6px;}
.login-logo span{color:var(--green);}
.login-desc{font-size:13px;color:var(--muted);margin-bottom:24px;line-height:1.6;}
.role-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;}
.role-card{background:var(--s1);border:1.5px solid var(--border);border-radius:12px;padding:16px;cursor:pointer;transition:all .18s;}
.role-card:hover,.role-card.sel{border-color:var(--green);background:#0a1f12;}
.role-card i{font-size:24px;display:block;margin-bottom:8px;}
.role-card .rn{font-size:13px;font-weight:700;}
.role-card .rs{font-size:11px;color:var(--muted);margin-top:2px;}
.tech-card{background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-top:16px;font-size:12px;color:var(--muted);line-height:1.9;}
.tech-card .tc-title{font-size:10px;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;display:flex;align-items:center;gap:5px;}
.tech-card b{color:var(--text);}

/* ════ HOME ════ */
.search-trigger{margin:14px 24px 16px;background:var(--s1);border:1.5px solid var(--border);border-radius:var(--r);padding:13px 16px;cursor:pointer;display:flex;align-items:center;gap:12px;transition:all .15s;flex-shrink:0;}
.search-trigger:hover{border-color:var(--green);background:#0a1f12;}
.search-trigger:hover .st-text{color:var(--text);}
.st-dot{width:10px;height:10px;border-radius:50%;background:var(--green);flex-shrink:0;}
.st-text{font-size:14px;color:var(--muted);transition:color .15s;}
.st-icon{margin-left:auto;color:var(--muted);font-size:18px;}
.svc-wrap{padding:0 24px;margin-bottom:18px;flex-shrink:0;}
.svc-title{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.07em;text-transform:uppercase;margin-bottom:10px;}
.svc-row{display:flex;gap:8px;}
.svc{flex:1;background:var(--s1);border:1.5px solid var(--border);border-radius:var(--r);padding:14px 10px;cursor:pointer;text-align:center;transition:all .15s;}
.svc:hover,.svc.sel{background:#0a1f12;border-color:var(--green);}
.svc i{font-size:22px;display:block;margin-bottom:6px;}
.svc-n{font-size:12px;font-weight:700;}
.svc-s{font-size:10px;color:var(--muted);margin-top:2px;}
.recent-section{padding:0 24px;}
.rs-title{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.07em;text-transform:uppercase;margin-bottom:10px;}
.ri{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #111;cursor:pointer;transition:opacity .15s;}
.ri:hover{opacity:.75;}
.ri:last-child{border-bottom:none;}
.ri-ic{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:16px;}
.ri-name{font-size:13px;font-weight:600;}
.ri-sub{font-size:11px;color:var(--muted);margin-top:1px;}
.ri-dist{font-size:11px;color:var(--muted);margin-left:auto;flex-shrink:0;padding-left:10px;}

/* ════ SEARCH / DEST ════ */
.dest-hd{padding:14px 20px;display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--border);flex-shrink:0;}
.back-btn{width:34px;height:34px;border-radius:50%;background:var(--s2);border:1px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text);font-size:16px;flex-shrink:0;transition:background .15s;}
.back-btn:hover{background:var(--s3);}
.route-inputs{padding:14px 20px;background:var(--s1);border-bottom:1px solid var(--border);flex-shrink:0;}
.rp-row{display:flex;align-items:center;gap:10px;margin-bottom:7px;}
.rp-row:last-child{margin-bottom:0;}
.rp-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;}
.rp-vline{width:2px;height:16px;background:var(--border);margin:0 5px;}
.rp-input{flex:1;background:var(--s2);border:1.5px solid transparent;border-radius:8px;padding:10px 14px;font-size:14px;color:var(--text);font-family:var(--font);outline:none;transition:border .15s;}
.rp-input:focus{border-color:var(--green);background:#0a1f12;}
.rp-input::placeholder{color:var(--muted);}
.rp-clear{width:22px;height:22px;border-radius:50%;background:var(--s3);border:none;cursor:pointer;color:var(--text);font-size:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.add-stop-row{padding:8px 20px 4px;flex-shrink:0;}
.add-stop-btn{display:flex;align-items:center;gap:6px;background:transparent;border:none;color:var(--green);font-size:12px;font-weight:600;cursor:pointer;padding:4px 0;transition:opacity .15s;}
.add-stop-btn:hover{opacity:.7;}

/* SEARCH RESULTS */
.sr-container{flex:1;overflow-y:auto;position:relative;}
.sr-container::-webkit-scrollbar{width:4px;}
.sr-container::-webkit-scrollbar-thumb{background:var(--s3);border-radius:2px;}
.sr-loading{padding:28px 20px;text-align:center;display:none;}
.sr-spin{display:inline-block;width:26px;height:26px;border:2.5px solid var(--border);border-top-color:var(--green);border-radius:50%;animation:spin 1s linear infinite;margin-bottom:12px;}
.sr-loading-txt{font-size:12px;color:var(--muted);}
.sr-group-label{padding:12px 20px 6px;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;display:flex;align-items:center;gap:6px;border-top:1px solid var(--border);}
.sr-group-label:first-child{border-top:none;}
.sr-group-label.green{color:var(--green);}
.sr-result{display:flex;align-items:center;gap:14px;padding:12px 20px;cursor:pointer;transition:background .1s;border-bottom:1px solid #0d0d0d;}
.sr-result:hover{background:var(--s1);}
.sr-result:last-child{border-bottom:none;}
.sr-r-ic{width:40px;height:40px;border-radius:50%;background:var(--s2);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:17px;color:var(--muted);}
.sr-r-ic.hosp{background:#0a1f12;color:var(--green);}
.sr-r-ic.road{background:#0a0f1f;color:var(--blue);}
.sr-r-ic.city{background:#1f1500;color:var(--amber);}
.sr-r-name{font-size:14px;font-weight:500;line-height:1.3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.sr-r-name b{color:#fff;font-weight:700;}
.sr-r-addr{font-size:12px;color:var(--muted);margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.sr-r-dist{font-size:12px;color:var(--muted);margin-left:auto;flex-shrink:0;padding-left:10px;min-width:44px;text-align:right;font-weight:500;}
.sr-empty{padding:40px 20px;text-align:center;color:var(--muted);}
.sr-empty i{font-size:32px;display:block;margin-bottom:10px;opacity:.3;}
.sr-footer{padding:10px 20px;display:flex;align-items:center;gap:6px;color:var(--muted);font-size:11px;border-top:1px solid var(--border);}

/* ════ VTYPE ════ */
.vtype-scroll{flex:1;overflow-y:auto;padding:16px 20px;}
.vtype-scroll::-webkit-scrollbar{width:4px;}
.route-summary-box{background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:12px 14px;margin-bottom:16px;font-size:13px;}
.route-summary-box b{color:var(--text);}
.vtc{background:var(--s1);border:1.5px solid var(--border);border-radius:var(--r);padding:16px;margin-bottom:10px;cursor:pointer;display:flex;align-items:center;gap:14px;transition:all .15s;}
.vtc:hover,.vtc.sel{border-color:var(--green);background:#0a1f12;}
.vtc-icon i{font-size:32px;}
.vtc-name{font-size:15px;font-weight:700;}
.vtc-desc{font-size:12px;color:var(--muted);margin-top:3px;}
.vtc-eta{font-size:12px;color:var(--green);font-weight:600;margin-top:4px;display:flex;align-items:center;gap:5px;}
.vtc-dist{margin-left:auto;text-align:right;flex-shrink:0;}
.vtc-dist-v{font-size:17px;font-weight:800;}
.vtc-dist-l{font-size:11px;color:var(--muted);}
.form-section{background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:14px;}
.form-section-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px;}
.pulse{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--green);animation:pk 1.5s infinite;}
@keyframes pk{0%,100%{transform:scale(1);}50%{transform:scale(1.6);opacity:.5;}}

/* ════ CONFIRM ════ */
.confirm-scroll{flex:1;overflow-y:auto;padding:20px;}
.confirm-scroll::-webkit-scrollbar{width:4px;}
.status-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
.status-text h2{font-size:20px;font-weight:800;line-height:1.2;}
.status-text p{font-size:13px;color:var(--muted);margin-top:4px;}
.spin-ring{width:38px;height:38px;border:3px solid var(--border);border-top-color:var(--green);border-radius:50%;animation:spin 1s linear infinite;}
.trip-stats{display:flex;gap:10px;margin-bottom:18px;}
.tstat{flex:1;background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:12px;text-align:center;}
.tstat-v{font-size:18px;font-weight:800;}
.tstat-l{font-size:11px;color:var(--muted);margin-top:2px;}
.driver-box{display:flex;align-items:center;gap:14px;background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:14px;transition:opacity .5s;}
.drv-av{width:48px;height:48px;border-radius:50%;background:var(--s3);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800;flex-shrink:0;}

/* ════ RIDING ════ */
.riding-inner{flex:1;padding:20px;display:flex;flex-direction:column;}
.prog-bar{height:4px;background:var(--s2);border-radius:2px;margin-bottom:18px;overflow:hidden;}
.prog-fill{height:100%;background:var(--green);border-radius:2px;animation:prog 14s linear forwards;}
@keyframes prog{from{width:2%}to{width:100%}}
.driver-row{display:flex;align-items:center;gap:14px;margin-bottom:16px;}
.drv-av-sm{width:46px;height:46px;border-radius:50%;background:var(--s2);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:15px;}
.dest-box{background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:13px;margin-bottom:16px;}
.dest-box-label{font-size:11px;color:var(--muted);margin-bottom:5px;}
.dest-box-name{font-size:14px;font-weight:600;}
.ride-actions{display:flex;gap:10px;margin-top:auto;}
.ride-btn{flex:1;padding:12px;border-radius:var(--r);font-size:13px;font-weight:700;cursor:pointer;border:none;font-family:var(--font);transition:all .15s;}

/* ════ CHAT ════ */
.chat-msgs{flex:1;overflow-y:auto;padding:16px 20px;display:flex;flex-direction:column;gap:10px;}
.chat-msgs::-webkit-scrollbar{width:4px;}
.msg{max-width:78%;padding:11px 14px;border-radius:14px;font-size:13px;line-height:1.5;}
.msg.me{background:var(--green);color:#000;align-self:flex-end;border-bottom-right-radius:4px;}
.msg.other{background:var(--s2);color:var(--text);align-self:flex-start;border-bottom-left-radius:4px;}
.msg-time{font-size:10px;opacity:.55;margin-top:3px;}
.chat-input-bar{display:flex;gap:10px;padding:12px 20px;border-top:1px solid var(--border);flex-shrink:0;}
.chat-input-field{flex:1;background:var(--s2);border:1.5px solid var(--border);border-radius:24px;padding:10px 16px;font-size:14px;color:var(--text);font-family:var(--font);outline:none;transition:border .15s;}
.chat-input-field:focus{border-color:var(--green);}
.chat-send-btn{width:42px;height:42px;border-radius:50%;background:var(--green);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}

/* ════ RATING ════ */
.rating-inner{flex:1;overflow-y:auto;padding:24px 20px;}
.stars-row{display:flex;gap:10px;justify-content:center;margin:18px 0;}
.star{font-size:38px;cursor:pointer;opacity:.2;transition:all .15s;}
.star.on{opacity:1;}
.tags-row{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px;}
.rtag{padding:7px 14px;border-radius:20px;background:var(--s1);border:1.5px solid var(--border);font-size:12px;cursor:pointer;transition:all .15s;}
.rtag.sel{background:var(--green);color:#000;border-color:var(--green);}

/* ════ DRIVER PANEL ════ */
.drv-header{padding:16px 20px;border-bottom:1px solid var(--border);flex-shrink:0;}
.drv-status-line{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.toggle-wrap{display:flex;align-items:center;gap:10px;}
.tog{position:relative;width:54px;height:28px;background:var(--s2);border-radius:14px;cursor:pointer;border:none;transition:background .25s;}
.tog.on{background:var(--green);}
.tog-knob{position:absolute;top:3px;left:3px;width:22px;height:22px;border-radius:50%;background:#fff;transition:left .25s;box-shadow:0 1px 4px rgba(0,0,0,.3);}
.tog.on .tog-knob{left:29px;}
.earn-row{display:flex;gap:10px;}
.earn-box{flex:1;background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:12px;text-align:center;}
.earn-v{font-size:20px;font-weight:800;color:var(--green);}
.earn-l{font-size:11px;color:var(--muted);margin-top:2px;}
.req-card{margin:14px 20px;background:var(--s1);border:2px solid var(--green);border-radius:var(--r);padding:16px;animation:pb 1.5s ease-in-out infinite;}
@keyframes pb{0%,100%{border-color:var(--green);}50%{border-color:var(--gd);}}
.req-timer{height:3px;background:var(--s2);border-radius:2px;margin-bottom:12px;overflow:hidden;}
.req-timer-fill{height:100%;background:var(--amber);animation:drain 15s linear forwards;}
@keyframes drain{from{width:100%}to{width:0%}}
.req-actions{display:flex;gap:10px;}

/* ════ ACTIVITY ════ */
.activity-scroll{flex:1;overflow-y:auto;padding:16px 20px;}
.activity-scroll::-webkit-scrollbar{width:4px;}
.trip-card{background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:10px;cursor:pointer;transition:border .15s;}
.trip-card:hover{border-color:var(--muted);}
.trip-card-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:8px;}
.trip-route{font-size:14px;font-weight:600;}
.trip-meta{font-size:12px;color:var(--muted);margin-top:3px;}
.trip-foot{display:flex;justify-content:space-between;margin-top:10px;padding-top:10px;border-top:1px solid var(--border);font-size:12px;color:var(--muted);}
.pill{display:inline-flex;align-items:center;gap:3px;font-size:11px;font-weight:700;padding:3px 9px;border-radius:20px;}
.pill-g{background:rgba(6,193,103,.12);color:var(--green);}
.pill-r{background:rgba(209,41,61,.12);color:var(--red);}
.pill-a{background:rgba(245,166,35,.12);color:var(--amber);}

/* ════ MENU ════ */
.menu-user{padding:20px;border-bottom:1px solid var(--border);}
.mu-av{width:56px;height:56px;border-radius:50%;background:var(--s2);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:800;margin-bottom:12px;}
.mu-name{font-size:18px;font-weight:800;}
.mu-role{font-size:12px;color:var(--muted);margin-top:3px;}
.menu-item{display:flex;align-items:center;gap:14px;padding:13px 20px;cursor:pointer;transition:background .12s;border-bottom:1px solid #0d0d0d;}
.menu-item:hover{background:var(--s1);}
.mi-ic{width:36px;height:36px;border-radius:50%;background:var(--s2);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:16px;}
.mi-text{flex:1;}
.mi-label{font-size:14px;font-weight:600;}
.mi-sub{font-size:11px;color:var(--muted);margin-top:1px;}

/* ════ SHEETS ════ */
.sh-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);z-index:200;display:none;align-items:center;justify-content:center;}
.sh-overlay.open{display:flex;}
.sheet{background:var(--s1);border:1px solid var(--border);border-radius:16px;width:540px;max-width:92vw;max-height:88vh;display:flex;flex-direction:column;box-shadow:0 24px 80px rgba(0,0,0,.8);}
.sh-head{padding:18px 20px 14px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);flex-shrink:0;}
.sh-head h3{font-size:17px;font-weight:700;}
.sh-close{background:var(--s2);border:none;border-radius:50%;width:30px;height:30px;cursor:pointer;color:var(--text);display:flex;align-items:center;justify-content:center;font-size:16px;transition:background .15s;}
.sh-close:hover{background:var(--s3);}
.sh-body{padding:18px 20px;overflow-y:auto;flex:1;}
.sh-body::-webkit-scrollbar{width:4px;}
.sh-body::-webkit-scrollbar-thumb{background:var(--s3);}

/* ════ INCOMING ════ */
.inc-overlay{position:fixed;inset:0;z-index:300;background:rgba(0,0,0,.8);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;}
.inc-overlay.open{display:flex;}
.inc-box{background:var(--s1);border:1px solid var(--border);border-radius:16px;width:420px;padding:24px;box-shadow:0 24px 80px rgba(0,0,0,.9);animation:slideUp .3s ease;}
@keyframes slideUp{from{transform:translateY(20px);opacity:0;}to{transform:translateY(0);opacity:1;}}

/* ════ FIN ════ */
.fin-stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:18px;}
.fin-stat{background:var(--s2);border-radius:var(--r);padding:13px;text-align:center;}
.fin-stat-v{font-size:18px;font-weight:800;}
.fin-stat-l{font-size:11px;color:var(--muted);margin-top:2px;}
.fin-bar-wrap{margin-bottom:10px;}
.fin-bar{height:5px;background:var(--s2);border-radius:3px;margin-top:5px;}
.fin-fill{height:100%;border-radius:3px;}

/* ════ TOAST ════ */
.toast{position:fixed;top:20px;right:20px;background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:12px 18px;font-size:13px;font-weight:600;color:var(--text);z-index:999;opacity:0;transform:translateY(-8px);transition:all .3s;pointer-events:none;box-shadow:0 8px 32px rgba(0,0,0,.6);max-width:360px;line-height:1.4;}
.toast.show{opacity:1;transform:translateY(0);}

@keyframes spin{to{transform:rotate(360deg)}}
@keyframes gps-pulse{0%{transform:scale(.5);opacity:.8;}100%{transform:scale(2.8);opacity:0;}}
</style>
</head>
<body>
<div id="app">

<!-- ══════════════ PANEL ══════════════ -->
<div id="panel">

  <!-- LOGIN -->
  <div class="scr active" id="scr-login">
    <div class="ph" style="padding-bottom:0;">
      <div class="login-logo">HM<span>Pá</span></div>
    </div>
    <div class="panel-scroll" style="padding:4px 24px 24px;">
      <div class="login-desc">Sistema de Transporte Hospitalar<br/>Hospital da Mulher do Pará — Belém/PA</div>
      <div class="role-grid">
        <div class="role-card sel" id="rc-pass" onclick="selRole('pass')"><i class="ti ti-user" style="color:var(--green);"></i><div class="rn">Solicitante</div><div class="rs">Solicitar transporte</div></div>
        <div class="role-card" id="rc-drv" onclick="selRole('drv')"><i class="ti ti-steering-wheel" style="color:var(--blue);"></i><div class="rn">Motorista</div><div class="rs">Gerenciar corridas</div></div>
        <div class="role-card" id="rc-ges" onclick="selRole('ges')"><i class="ti ti-chart-bar" style="color:var(--amber);"></i><div class="rn">Gestor</div><div class="rs">Painel gerencial</div></div>
        <div class="role-card" id="rc-adm" onclick="selRole('adm')"><i class="ti ti-settings" style="color:var(--red);"></i><div class="rn">Administrador</div><div class="rs">Acesso total</div></div>
      </div>
      <div class="f-grp"><label class="f-lbl">Matrícula / Crachá</label><input class="f-in" id="login-mat" value="HMPá-0042"/></div>
      <div class="f-grp"><label class="f-lbl">Senha</label><input class="f-in" type="password" value="123456"/></div>
      <button class="btn" onclick="doLogin()"><i class="ti ti-login"></i> Acessar sistema</button>
      <div class="tech-card">
        <div class="tc-title"><i class="ti ti-stack" style="font-size:12px;"></i> Stack open source</div>
        <div>🗺 <b>Leaflet</b> + <b>OpenStreetMap</b></div>
        <div>🔍 <b>Nominatim</b> — geocoding de endereços</div>
        <div>🛣 <b>OSRM</b> — roteamento e distâncias</div>
        <div>🗄 <b>PostgreSQL + PostGIS</b> — banco geoespacial</div>
      </div>
    </div>
  </div>

  <!-- HOME -->
  <div class="scr" id="scr-home">
    <div class="ph">
      <div class="ph-top">
        <div><div class="ph-title" id="home-greeting">Bom dia 👋</div><div class="ph-sub">Hospital da Mulher do Pará</div></div>
        <div style="display:flex;gap:8px;">
          <button class="btn-icon" onclick="openSheet('sh-notif')" style="position:relative;"><i class="ti ti-bell"></i><div class="badge-dot"></div></button>
          <button class="btn-icon" onclick="gotoScr('scr-menu')"><i class="ti ti-menu-2"></i></button>
        </div>
      </div>
    </div>
    <div class="divider"></div>
    <div class="search-trigger" onclick="gotoScr('scr-dest')">
      <div class="st-dot"></div>
      <span class="st-text">Para onde você vai?</span>
      <i class="ti ti-search st-icon"></i>
    </div>
    <div class="svc-wrap">
      <div class="svc-title">Tipo de transporte</div>
      <div class="svc-row">
        <div class="svc sel" onclick="selSvc(this,'amb')"><i class="ti ti-ambulance" style="color:var(--red);"></i><div class="svc-n">Ambulância</div><div class="svc-s">Transporte clínico</div></div>
        <div class="svc" onclick="selSvc(this,'apoio')"><i class="ti ti-car-suv" style="color:var(--blue);"></i><div class="svc-n">Carro de apoio</div><div class="svc-s">Pessoal / material</div></div>
        <div class="svc" onclick="selSvc(this,'self')"><i class="ti ti-user" style="color:var(--amber);"></i><div class="svc-n">Eu mesmo</div><div class="svc-s">Demanda própria</div></div>
      </div>
    </div>
    <div class="panel-scroll">
      <div class="recent-section">
        <div class="rs-title">Destinos frequentes</div>
        <div id="home-recent"></div>
      </div>
    </div>
    <nav class="nav-bar">
      <button class="nav-btn on" onclick="gotoScr('scr-home');setNav(this)"><i class="ti ti-home"></i><span>Início</span></button>
      <button class="nav-btn" onclick="gotoScr('scr-activity');setNav(this)"><i class="ti ti-clock"></i><span>Atividade</span></button>
      <button class="nav-btn" onclick="openSheet('sh-relatorio')"><i class="ti ti-chart-bar"></i><span>Relatório</span></button>
      <button class="nav-btn" onclick="gotoScr('scr-menu');setNav(this)"><i class="ti ti-menu-2"></i><span>Menu</span></button>
    </nav>
  </div>

  <!-- DEST / SEARCH -->
  <div class="scr" id="scr-dest">
    <div class="dest-hd">
      <button class="back-btn" onclick="gotoScr('scr-home')"><i class="ti ti-arrow-left"></i></button>
      <div><div style="font-size:15px;font-weight:700;">Planeje sua viagem</div><div style="font-size:12px;color:var(--muted);margin-top:2px;">Digite para buscar qualquer endereço</div></div>
    </div>
    <div class="route-inputs">
      <div class="rp-row">
        <div class="rp-dot" style="background:var(--green);"></div>
        <input class="rp-input" value="Hospital da Mulher do Pará — Av. Gentil Bittencourt, 2175" readonly style="color:var(--muted);"/>
      </div>
      <div class="rp-vline" style="margin-left:5px;"></div>
      <div id="extra-stops"></div>
      <div class="rp-row">
        <div class="rp-dot" style="background:#fff;border:2.5px solid var(--muted);box-sizing:border-box;"></div>
        <input class="rp-input" id="dest-input" placeholder="Para onde? Rua, bairro, cidade…" oninput="onDestIn(this.value)" onkeyup="onDestIn(this.value)" autocomplete="off" autocorrect="off" spellcheck="false"/>
        <button id="dest-clear" onclick="clearSearch()" style="display:none;" class="rp-clear"><i class="ti ti-x"></i></button>
      </div>
    </div>
    <div class="add-stop-row">
      <button class="add-stop-btn" onclick="addStop()"><i class="ti ti-plus" style="font-size:13px;"></i> Adicionar parada no percurso</button>
    </div>
    <div class="sr-container" id="sr-container">
      <div class="sr-loading" id="sr-loading">
        <div class="sr-spin"></div>
        <div class="sr-loading-txt">Buscando no OpenStreetMap / Nominatim…</div>
      </div>
      <div id="sr-body"></div>
    </div>
  </div>

  <!-- VTYPE -->
  <div class="scr" id="scr-vtype">
    <div class="dest-hd">
      <button class="back-btn" onclick="gotoScr('scr-dest')"><i class="ti ti-arrow-left"></i></button>
      <div><div style="font-size:15px;font-weight:700;">Escolher veículo</div><div style="font-size:12px;color:var(--muted);margin-top:2px;" id="vtype-sub">—</div></div>
    </div>
    <div class="vtype-scroll">
      <div class="route-summary-box" id="route-summary">Calculando rota com OSRM…</div>
      <div class="vtc sel" onclick="selVtype(this,'amb')">
        <div class="vtc-icon"><i class="ti ti-ambulance" style="color:var(--red);"></i></div>
        <div style="flex:1;"><div class="vtc-name">Ambulância</div><div class="vtc-desc">Transporte clínico de pacientes</div><div class="vtc-eta"><span class="pulse"></span> Amb.01 disponível · ~3 min</div></div>
        <div class="vtc-dist"><div class="vtc-dist-v" id="km-amb">—</div><div class="vtc-dist-l">distância</div></div>
      </div>
      <div class="vtc" onclick="selVtype(this,'apoio')">
        <div class="vtc-icon"><i class="ti ti-car-suv" style="color:var(--blue);"></i></div>
        <div style="flex:1;"><div class="vtc-name">Carro de apoio</div><div class="vtc-desc">Funcionários, materiais e documentos</div><div class="vtc-eta"><span class="pulse"></span> Apoio02 disponível · ~5 min</div></div>
        <div class="vtc-dist"><div class="vtc-dist-v" id="km-apoio">—</div><div class="vtc-dist-l">distância</div></div>
      </div>
      <div id="form-amb" class="form-section">
        <div class="form-section-title" style="color:var(--red);">Dados do paciente</div>
        <div class="f-grp"><label class="f-lbl">Nome completo</label><input class="f-in" placeholder="Nome do paciente"/></div>
        <div class="f-row">
          <div class="f-grp"><label class="f-lbl">Prontuário</label><input class="f-in" placeholder="Nº"/></div>
          <div class="f-grp"><label class="f-lbl">Estado clínico</label><select class="f-sel"><option>Estável</option><option>Grave</option><option>Crítico</option></select></div>
        </div>
        <div class="f-grp"><label class="f-lbl">Suporte necessário</label><select class="f-sel"><option>Nenhum</option><option>Oxigênio</option><option>Maca + soro</option><option>UTI móvel</option></select></div>
      </div>
      <div id="form-apoio" class="form-section" style="display:none;">
        <div class="form-section-title" style="color:var(--blue);">Dados do transporte</div>
        <div class="f-grp"><label class="f-lbl">Categoria</label><select class="f-sel"><option>Funcionário</option><option>Medicamento</option><option>Material</option><option>Documento</option></select></div>
        <div class="f-grp"><label class="f-lbl">Descrição dos itens</label><input class="f-in" placeholder="O que será transportado?"/></div>
      </div>
      <button class="btn" onclick="confirmRide()"><i class="ti ti-send"></i> Confirmar solicitação</button>
    </div>
  </div>

  <!-- CONFIRM -->
  <div class="scr" id="scr-confirm">
    <div class="dest-hd"><div style="font-size:15px;font-weight:700;">Aguardando motorista</div></div>
    <div class="confirm-scroll">
      <div class="status-row">
        <div class="status-text"><h2 id="conf-st">Procurando motorista…</h2><p id="conf-sub">Alocando veículo disponível</p></div>
        <div class="spin-ring" id="conf-spin"></div>
      </div>
      <div class="trip-stats">
        <div class="tstat"><div class="tstat-v" id="cf-km">—</div><div class="tstat-l">Distância</div></div>
        <div class="tstat"><div class="tstat-v" id="cf-eta">—</div><div class="tstat-l">Tempo est.</div></div>
        <div class="tstat"><div class="tstat-v" id="cf-custo">—</div><div class="tstat-l">Custo/km</div></div>
      </div>
      <div class="driver-box" id="drv-preview" style="opacity:0;transition:opacity .5s;">
        <div class="drv-av">JR</div>
        <div style="flex:1;"><div style="font-size:15px;font-weight:700;">João Rodrigues</div><div style="font-size:12px;color:var(--muted);margin-top:2px;">Amb.01 · HPA-1234 · Renault Master</div><div style="font-size:12px;color:var(--amber);margin-top:3px;">★★★★★ 4.9</div></div>
        <div style="text-align:right;font-size:12px;"><div style="color:var(--muted);">Hodômetro</div><div style="font-weight:700;margin-top:2px;" id="cf-hod">—</div></div>
      </div>
      <button class="btn-ghost" onclick="cancelRide()"><i class="ti ti-x"></i> Cancelar solicitação</button>
    </div>
  </div>

  <!-- RIDING -->
  <div class="scr" id="scr-riding">
    <div class="dest-hd" style="border-color:rgba(6,193,103,.3);">
      <div style="width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0;animation:pk 1.5s infinite;"></div>
      <div style="font-size:15px;font-weight:700;color:var(--green);">Corrida em andamento</div>
    </div>
    <div class="riding-inner">
      <div class="prog-bar"><div class="prog-fill"></div></div>
      <div class="driver-row">
        <div class="drv-av-sm">JR</div>
        <div style="flex:1;"><div style="font-size:15px;font-weight:700;">João Rodrigues</div><div style="font-size:12px;color:var(--muted);margin-top:2px;">Amb.01 · HPA-1234 · <span style="color:var(--green);">Em rota</span></div></div>
        <button class="btn-icon" onclick="gotoScr('scr-chat')"><i class="ti ti-message"></i></button>
      </div>
      <div class="dest-box"><div class="dest-box-label">Destino</div><div class="dest-box-name" id="riding-dest-name">—</div></div>
      <div class="ride-actions">
        <button class="ride-btn" style="background:var(--s2);color:var(--text);" onclick="toast('📞 Ligando para João Rodrigues…')"><i class="ti ti-phone"></i> Ligar</button>
        <button class="ride-btn" style="background:var(--red);color:#fff;" onclick="cancelRide()"><i class="ti ti-x"></i> Cancelar</button>
        <button class="ride-btn" style="background:var(--green);color:#000;" onclick="finishRide()"><i class="ti ti-check"></i> Concluir</button>
      </div>
    </div>
  </div>

  <!-- RATING -->
  <div class="scr" id="scr-rating">
    <div class="dest-hd"><div style="font-size:15px;font-weight:700;">Avaliar a corrida</div></div>
    <div class="rating-inner">
      <div style="text-align:center;margin-bottom:4px;"><div style="font-size:22px;font-weight:800;">Como foi?</div><div style="font-size:13px;color:var(--muted);margin-top:4px;">João Rodrigues · Ambulância 01</div></div>
      <div class="stars-row" id="stars">
        <span class="star on" onclick="rateStar(1)">★</span><span class="star on" onclick="rateStar(2)">★</span><span class="star on" onclick="rateStar(3)">★</span><span class="star on" onclick="rateStar(4)">★</span><span class="star on" onclick="rateStar(5)">★</span>
      </div>
      <div class="tags-row">
        <div class="rtag" onclick="this.classList.toggle('sel')">Pontual</div>
        <div class="rtag" onclick="this.classList.toggle('sel')">Cuidadoso</div>
        <div class="rtag" onclick="this.classList.toggle('sel')">Gentil</div>
        <div class="rtag" onclick="this.classList.toggle('sel')">Veículo limpo</div>
        <div class="rtag" onclick="this.classList.toggle('sel')">Comunicativo</div>
        <div class="rtag" onclick="this.classList.toggle('sel')">Rota correta</div>
      </div>
      <div class="f-grp"><label class="f-lbl">Comentário (opcional)</label><textarea class="f-in" rows="3" placeholder="Deixe um feedback…" style="resize:none;"></textarea></div>
      <button class="btn" onclick="submitRating()" style="margin-top:8px;"><i class="ti ti-check"></i> Enviar avaliação</button>
      <button class="btn-ghost" onclick="gotoScr('scr-home')" style="margin-top:8px;">Pular</button>
    </div>
  </div>

  <!-- CHAT -->
  <div class="scr" id="scr-chat">
    <div class="dest-hd">
      <button class="back-btn" onclick="gotoScr('scr-riding')"><i class="ti ti-arrow-left"></i></button>
      <div style="flex:1;"><div style="font-size:15px;font-weight:700;">João Rodrigues</div><div style="font-size:11px;color:var(--green);margin-top:2px;display:flex;align-items:center;gap:5px;"><span style="width:6px;height:6px;border-radius:50%;background:var(--green);display:inline-block;"></span>Online · Em rota</div></div>
      <button class="btn-icon" onclick="toast('📞 Ligando para João…')"><i class="ti ti-phone"></i></button>
    </div>
    <div class="chat-msgs" id="chat-msgs">
      <div class="msg other">Estou a caminho! Chego em aproximadamente 4 minutos.<div class="msg-time">agora</div></div>
    </div>
    <div class="chat-input-bar">
      <input class="chat-input-field" id="chat-in" placeholder="Digite uma mensagem…" onkeydown="if(event.key==='Enter')sendMsg()"/>
      <button class="chat-send-btn" onclick="sendMsg()"><i class="ti ti-send" style="font-size:16px;color:#000;"></i></button>
    </div>
  </div>

  <!-- DRIVER PANEL -->
  <div class="scr" id="scr-driver">
    <div class="drv-header">
      <div class="drv-status-line">
        <div>
          <div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Status do turno</div>
          <div class="toggle-wrap">
            <button class="tog on" id="tog-btn" onclick="toggleOnline()"><div class="tog-knob"></div></button>
            <span style="font-size:15px;font-weight:700;" id="online-lbl">Online</span>
          </div>
        </div>
        <div style="text-align:right;">
          <div style="font-size:14px;font-weight:700;" id="drv-pname">João Rodrigues</div>
          <div style="font-size:12px;color:var(--muted);margin-top:2px;">Amb.01 · HPA-1234</div>
          <div style="font-size:12px;color:var(--amber);margin-top:2px;">★ 4.9</div>
        </div>
      </div>
      <div class="earn-row">
        <div class="earn-box"><div class="earn-v" id="earn-trips">18</div><div class="earn-l">Corridas hoje</div></div>
        <div class="earn-box"><div class="earn-v">412</div><div class="earn-l">Km rodados</div></div>
        <div class="earn-box"><div class="earn-v">~8h</div><div class="earn-l">Em serviço</div></div>
      </div>
    </div>
    <div class="req-card" id="req-card">
