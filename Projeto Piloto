function startGPS(){
  if(!navigator.geolocation)return;
  navigator.geolocation.watchPosition(pos=>{
    const ll=[pos.coords.latitude,pos.coords.longitude];
    userPos={lat:pos.coords.latitude,lng:pos.coords.longitude};
    if(!userMk){
      userMk=L.marker(ll,{icon:gpsIcon,zIndexOffset:1000}).addTo(map);
      userCircle=L.circle(ll,{radius:pos.coords.accuracy||30,color:'#276EF1',fillColor:'#276EF1',fillOpacity:.08,weight:1.5}).addTo(map);
      map.setView(ll,16);
    }else{
      userMk.setLatLng(ll);
      userCircle.setLatLng(ll);
      userCircle.setRadius(pos.coords.accuracy||30);
    }
  },e=>console.warn('GPS:',e.message),{enableHighAccuracy:true,maximumAge:5000,timeout:10000});
}
